# Makefile for simulationCalculator

# Compiler
CXX = g++

# Compiler flags
CXXFLAGS = -std=c++20 -Wall

# Source files 
SRCS = main.cpp fluid.cpp geometry.cpp mesh.cpp simulation.cpp turbulence.cpp 

# Object files
OBJS = $(SRCS:.cpp=.o)

# Executable name
TARGET = simulationCalculator

# Default rule
all: $(TARGET)

# Rule to link object files into the executable
$(TARGET): $(OBJS)
	$(CXX) $(CXXFLAGS) -o $(TARGET) $(OBJS)

# Rule to compile source files into object files
%.o: %.cpp
	$(CXX) $(CXXFLAGS) -c $< -o $@

# Clean rule
clean:
	rm -f $(OBJS) $(TARGET)